APP_NAME="Self Order"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# --- Mobile/LAN testing (Vite dev server) ---
# If you want to open the app from a phone on the same Wi‑Fi while running `npm run dev`,
# set these to your PC's LAN IP so the phone can load CSS/JS from the Vite server.
# Example:
# VITE_PORT=5173
# VITE_DEV_SERVER_URL=http://192.168.1.10:5173
# VITE_HMR_HOST=192.168.1.10

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=self_order
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Realtime (Node.js Socket.IO)
REALTIME_ENABLED=true
REALTIME_SERVER_URL=http://127.0.0.1:3001
REALTIME_PUBLIC_URL=http://127.0.0.1:3001
REALTIME_SERVER_SECRET=change-me
REALTIME_TIMEOUT_SECONDS=1

# Payments (Dynamic QRIS provider)
# Midtrans Core API (recommended aggregator for Indonesia)
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
